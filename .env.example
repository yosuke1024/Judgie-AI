# Judgie-AI - Local Environment Settings Template
# Copy this file to '.env' and fill in your details.

# Application Environment ('local' or 'production')
APP_ENV=local

# Persistent Database URL (Only required in production)
# In local mode, a SQLite database is automatically created in 'data/judgie.db'
# DATABASE_URL=postgresql://user:pass@host:port/dbname

# --- OIDC / Google Login Settings (Optional Gateway Auth) ---
OIDC_ENABLED=false
OIDC_ISSUER=https://accounts.google.com
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=http://localhost:8501/
# Allow specific domains (comma-separated, empty to allow all)
OIDC_ALLOWED_DOMAINS=
# Allow specific individual emails (comma-separated)
OIDC_ALLOWED_EMAILS=

